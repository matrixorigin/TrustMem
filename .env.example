# Memoria — Environment Variables
# Copy to .env and fill in required values.

# ─── Required ───────────────────────────────────────────────
MEMORIA_MASTER_KEY=          # Admin API key, min 16 chars

# ─── Database (defaults work with bundled MatrixOne) ────────
# MEMORIA_DB_HOST=matrixone
# MEMORIA_DB_PORT=6001
# MEMORIA_DB_USER=root
# MEMORIA_DB_PASSWORD=111
# MEMORIA_DB_NAME=memoria

# ─── Embedding ──────────────────────────────────────────────
# Default: mock (no embedding, keyword search only)
# Option 1: OpenAI-compatible (recommended)
# MEMORIA_EMBEDDING_PROVIDER=openai
# MEMORIA_EMBEDDING_MODEL=text-embedding-3-small
# MEMORIA_EMBEDDING_DIM=1536                              # must match model output dimension
# MEMORIA_EMBEDDING_API_KEY=sk-...
# MEMORIA_EMBEDDING_BASE_URL=https://custom-endpoint/v1  # optional, e.g. SiliconFlow, Ollama

# Option 2: Local sentence-transformers (no API key, but requires INSTALL_EXTRAS=local-embedding at build time)
# MEMORIA_EMBEDDING_PROVIDER=local
# MEMORIA_EMBEDDING_MODEL=all-MiniLM-L6-v2
# MEMORIA_EMBEDDING_DIM=384

# ─── LLM (optional — for reflect + entity extraction) ──────
# Without this, reflect/extract_entities return candidates for your AI assistant to process.
# With this, Memoria uses its own LLM for synthesis/extraction.
# MEMORIA_LLM_API_KEY=sk-...
# MEMORIA_LLM_MODEL=deepseek-chat
# MEMORIA_LLM_BASE_URL=https://api.deepseek.com/v1   # any OpenAI-compatible endpoint

# ─── Ports (host-side) ─────────────────────────────────────
# API_PORT=8100
# MATRIXONE_PORT=6001
# MATRIXONE_DEBUG_PORT=6060   # Uncomment to expose MatrixOne pprof/debug port

# ─── Data Directory ─────────────────────────────────────────
# MATRIXONE_DATA_DIR=./data/matrixone   # default, relative to memoria/

# ─── Rate Limits (optional, format: max_requests,window_seconds) ────
# MEMORIA_RATE_LIMIT_AUTH_KEYS=20,60       # default: 20/min
# MEMORIA_RATE_LIMIT_STORE=300,60          # default: 300/min
# MEMORIA_RATE_LIMIT_RETRIEVE=600,60       # default: 600/min
# MEMORIA_RATE_LIMIT_CONSOLIDATE=3,3600    # default: 3/hour
# MEMORIA_RATE_LIMIT_REFLECT=2,7200        # default: 2/2h
# MEMORIA_RATE_LIMIT_DEFAULT=1000,60       # fallback: 1000/min

# ─── Build ──────────────────────────────────────────────────
# For local embedding support in Docker:
# INSTALL_EXTRAS=local-embedding
